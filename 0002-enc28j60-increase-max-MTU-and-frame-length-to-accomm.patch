From b00857036369789d6391f4cd8da3e53d0dfe4706 Mon Sep 17 00:00:00 2001
From: Albrecht Lohofener <albrechtloh@gmx.de>
Date: Wed, 15 Apr 2026 22:39:07 +0200
Subject: [PATCH] enc28j60: increase max MTU and frame length to accommodate
 DSA overhead

---
 drivers/net/ethernet/microchip/enc28j60.c    | 1 +
 drivers/net/ethernet/microchip/enc28j60_hw.h | 3 ++-
 2 files changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/net/ethernet/microchip/enc28j60.c b/drivers/net/ethernet/microchip/enc28j60.c
index d6c949153..60ff9684d 100644
--- a/drivers/net/ethernet/microchip/enc28j60.c
+++ b/drivers/net/ethernet/microchip/enc28j60.c
@@ -1575,6 +1575,7 @@ static int enc28j60_probe(struct spi_device *spi)
 	dev->netdev_ops = &enc28j60_netdev_ops;
 	dev->watchdog_timeo = TX_TIMEOUT;
 	dev->ethtool_ops = &enc28j60_ethtool_ops;
+	dev->max_mtu = 1508; /*  Increase max MTU by 8 bytes because DSA adds 8 bytes in my case (rtl8365 driver). */
 
 	enc28j60_lowpower(priv, true);
 
diff --git a/drivers/net/ethernet/microchip/enc28j60_hw.h b/drivers/net/ethernet/microchip/enc28j60_hw.h
index da4ab1725..0731b9bd8 100644
--- a/drivers/net/ethernet/microchip/enc28j60_hw.h
+++ b/drivers/net/ethernet/microchip/enc28j60_hw.h
@@ -302,7 +302,8 @@
 #define RXEND_INIT		0x19FF
 
 /* maximum ethernet frame length */
-#define MAX_FRAMELEN		1518
+/* Increase max frame len by 8 bytes because DSA adds 8 bytes in my case (rtl8365 driver). Original value was 1518. */
+#define MAX_FRAMELEN		1526
 
 /* Preferred half duplex: LEDA: Link status LEDB: Rx/Tx activity */
 #define ENC28J60_LAMPS_MODE	0x3476
-- 
2.47.3

